# URL absoluta da API (produção). Em dev, deixar vazio para usar proxy Vite /api → localhost:3333
VITE_API_BASE_URL=

# Vercel — proxy serverless /api (obrigatório se o frontend usa /api em produção)
# Copia o domínio público da Railway (Settings → Networking), sem barra no fim
# API_BASE_URL=https://xxx.up.railway.app
